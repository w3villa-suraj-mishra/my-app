<div class="min-h-screen bg-gray-50 p-8">

  <h1 class="text-4xl font-bold text-center text-blue-600 mb-10">
    Help Center 💬
  </h1>

  <div class="max-w-3xl mx-auto space-y-6">

    <div class="bg-white p-6 rounded-xl shadow">
      <h2 class="font-semibold text-lg">How to use this website?</h2>
      <p class="text-gray-600 mt-2">
        Navigate using the menu and explore different features easily.
      </p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow">
      <h2 class="font-semibold text-lg">How to create an account?</h2>
      <p class="text-gray-600 mt-2">
        Click on the signup button and fill in your details.
      </p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow">
      <h2 class="font-semibold text-lg">Forgot password?</h2>
      <p class="text-gray-600 mt-2">
        Use the forgot password option on the login page.
      </p>
    </div>

    <div class="text-center mt-8">
      <%= link_to "Back to Home", "/",
        class: "bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700" %>
    </div>

  </div>

</div>